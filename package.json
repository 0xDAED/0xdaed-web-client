{
  "name": "web-client",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .js,.vue,.ts,.tsx src",
    "lint:fix": "eslint --ext .js,.vue,.ts,.tsx src --fix",
    "jsdoc:add": "node scripts/add-jsdoc.js",
    "jsdoc:add:dry": "node scripts/add-jsdoc.js --dry-run",
    "jsdoc:restore": "find src -name '*.backup' -exec sh -c 'mv \"$1\" \"${1%.backup}\"' _ {} \\;",
    "jsdoc:clean": "find src -name '*.backup' -delete"
  },
  "dependencies": {
    "@fontsource/roboto": "5.2.7",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@mdi/font": "7.4.47",
    "chart.js": "^4.5.1",
    "vue": "^3.5.21",
    "vue-router": "4",
    "vuetify": "^3.10.1"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.0",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-standard": "^9.0.1",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "glob": "^13.0.1",
    "globals": "^17.3.0",
    "sass-embedded": "^1.92.1",
    "unplugin-fonts": "^1.4.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^7.1.5",
    "vite-plugin-vuetify": "^2.1.2"
  }
}
